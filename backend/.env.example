APP_NAME="Ministry of Economy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=surian_db
DB_USERNAME=surian_user
DB_PASSWORD=surian_pass

# Session (Redis recommended for production)
SESSION_DRIVER=database
SESSION_LIFETIME=15
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax

# Frontend URLs for CORS/Sanctum
FRONTEND_URL=http://localhost:3002
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8080,frontend-next:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache (Redis)
CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=failover
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS="noreply@economy.gov.sy"
MAIL_FROM_NAME="${APP_NAME}"

# SMS / OTP
SMS_PROVIDER=log
# Twilio
TWILIO_ACCOUNT_SID=null
TWILIO_AUTH_TOKEN=null
TWILIO_FROM_NUMBER=null
# Nexmo/Vonage
NEXMO_API_KEY=null
NEXMO_API_SECRET=null
NEXMO_FROM_NUMBER=MOE
# Syria SMS (Local Provider)
SYRIA_SMS_API_KEY=null
SYRIA_SMS_SENDER=MOE
SYRIA_SMS_BASE_URL=https://api.syriasms.com/send
# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
SMS_RATE_LIMIT_HOUR=10
SMS_RATE_LIMIT_DAY=50

# AI Service
AI_SERVICE_URL=http://ai-service:8000

# WhatsApp Business API (FR-53)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=null
WHATSAPP_ACCESS_TOKEN=null
WHATSAPP_BUSINESS_ACCOUNT_ID=null
WHATSAPP_VERIFY_TOKEN=moe_whatsapp_webhook_2026
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Telegram Bot API (FR-53)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=null
TELEGRAM_BOT_USERNAME=null
TELEGRAM_WEBHOOK_SECRET=moe_telegram_webhook_2026

# Civil Registry API
CIVIL_REGISTRY_ENABLED=false
CIVIL_REGISTRY_API_URL=https://civil-registry.gov.sy/api/v1
CIVIL_REGISTRY_API_KEY=
CIVIL_REGISTRY_API_SECRET=
CIVIL_REGISTRY_TIMEOUT=15
CIVIL_REGISTRY_RETRY_ATTEMPTS=3
CIVIL_REGISTRY_CACHE_TTL=3600
CIVIL_REGISTRY_VERIFY_SSL=true

# Suggestions Configuration
SUGGESTIONS_MAX_FILES=5
SUGGESTIONS_MAX_FILE_SIZE=10240
