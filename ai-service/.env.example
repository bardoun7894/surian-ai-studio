# AI Service Configuration

# Debug mode (disable in production)
DEBUG=true

# Service name
SERVICE_NAME=moe-ai-service

# AI Provider: "gemini", "openai", "ollama" (future), "local" (future)
AI_PROVIDER=gemini

# Google Gemini API (default provider)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API (alternative cloud provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama Settings (future - for open-source models)
# Install: https://ollama.ai/download
# Models: llama3.2, mistral, qwen2.5, codellama, etc.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Local Model Settings (future - direct inference)
# For llama.cpp, GGUF models, etc.
LOCAL_MODEL_PATH=/path/to/model.gguf
LOCAL_MODEL_TYPE=llama

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173","http://localhost:3000"]

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Chat settings
MAX_CONVERSATION_HISTORY=20
MAX_INPUT_LENGTH=4000
